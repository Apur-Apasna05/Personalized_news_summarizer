# ── API Keys ────────────────────────────────────────────────
GNEWS_API_KEY=your_gnews_api_key_here

# ── Storage ─────────────────────────────────────────────────
DB_PATH=data/news.db

# ── Ingestion settings ──────────────────────────────────────
GNEWS_MAX_ARTICLES=10
SCRAPER_MAX_ARTICLES=5

# ── Embedding Model (Phase 2 + 3) ───────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Ollama (Phase 2 + 3) ────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_MAX_TOKENS=300

# ── Processing / Clustering (Phase 2) ───────────────────────
HDBSCAN_MIN_CLUSTER_SIZE=3
HDBSCAN_MIN_SAMPLES=2
PROCESSING_MIN_BATCH=10

# ── ChromaDB (Phase 3) ──────────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=news_clusters

# ── RAG (Phase 3) ───────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.38

# ── Personalization (Phase 4) ────────────────────────────────
PERSONALIZATION_ALPHA=0.3
WEIGHT_LEARNING_RATE=0.1
WEIGHT_MIN=-1.0
WEIGHT_MAX=1.0
DWELL_NORMALISER=60.0
